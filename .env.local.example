# =============================================================================
# ViewTrack Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Or run `vercel login && vercel env pull .env.local` to pull from Vercel.
# .env.local is gitignored — never commit secrets.
# =============================================================================

# Firebase Admin
FIREBASE_PROJECT_ID=trackview-6a3a5
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=trackview-6a3a5.firebasestorage.app

# Apify (scraping)
APIFY_TOKEN=

# YouTube
YOUTUBE_API_KEY=

# Email (Resend)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Auth / Cron
CRON_SECRET=local-dev-secret

# Admin
ADMIN_EMAIL=ernesto@maktubtechnologies.com

# Optional
VITE_INSTAGRAM_SESSION_ID=
