{
  "functions": {
    "api/v1/**/*.ts": {
      "maxDuration": 120
    },
    "api/super-admin/*.ts": {
      "maxDuration": 120
    },
    "api/super-admin/**/*.ts": {
      "maxDuration": 120
    },
    "api/apify-proxy.ts": {
      "maxDuration": 300
    },
    "api/cron-refresh-videos.ts": {
      "maxDuration": 300
    },
    "api/cron-sync-accounts.ts": {
      "maxDuration": 300
    },
    "api/sync-single-account.ts": {
      "maxDuration": 300
    },
    "api/cron-process-videos.ts": {
      "maxDuration": 300
    },
    "api/process-single-video.ts": {
      "maxDuration": 300
    },
    "api/refresh-account.ts": {
      "maxDuration": 180
    },
    "api/cleanup-invalid-data.ts": {
      "maxDuration": 180
    },
    "api/cron-cleanup-invalid.ts": {
      "maxDuration": 180
    },
    "api/transcribe-video.ts": {
      "maxDuration": 120
    },
    "api/cron-orchestrator.ts": {
      "maxDuration": 60
    },
    "api/process-organization.ts": {
      "maxDuration": 60
    },
    "api/process-project.ts": {
      "maxDuration": 60
    },
    "api/cron-check-orphaned-sessions.ts": {
      "maxDuration": 60
    },
    "api/sync-usage-counts.ts": {
      "maxDuration": 60
    },
    "api/cleanup-stuck-items.ts": {
      "maxDuration": 60
    },
    "api/queue-worker.ts": {
      "maxDuration": 60
    },
    "api/stripe-webhook.ts": {
      "maxDuration": 30
    },
    "api/create-checkout-session.ts": {
      "maxDuration": 30
    },
    "api/create-portal-session.ts": {
      "maxDuration": 30
    },
    "api/youtube-channel.ts": {
      "maxDuration": 30
    },
    "api/test-grant-plan.ts": {
      "maxDuration": 30
    },
    "api/api-keys.ts": {
      "maxDuration": 15
    },
    "api/youtube-video.ts": {
      "maxDuration": 10
    },
    "api/redirect.ts": {
      "maxDuration": 10
    },
    "api/trigger-orchestrator.ts": {
      "maxDuration": 10
    },
    "api/queue-status.ts": {
      "maxDuration": 10
    },
    "api/trigger-queue-worker.ts": {
      "maxDuration": 10
    },
    "api/queue-manual-account.ts": {
      "maxDuration": 10
    },
    "api/queue-manual-video.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron-orchestrator",
      "schedule": "0 5,11,17,23 * * *"
    },
    {
      "path": "/api/queue-worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cleanup-stuck-items",
      "schedule": "*/15 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/l/([^/]+)",
      "dest": "/api/redirect?shortCode=$1"
    },
    {
      "src": "/([a-zA-Z0-9]{4,8})$",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[a-z0-9-]+)\\.viewtrack\\.app"
        }
      ],
      "dest": "/api/redirect?shortCode=$1&subdomain=$subdomain"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
